# ─── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SECRET_KEY=sb_secret_your-key-here
# Direct PostgreSQL connection string for migrations (optional, falls back to SUPABASE_URL)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ─── JWT (admin sessions) ──────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Server ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_MAX=100

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info
